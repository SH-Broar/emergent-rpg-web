 "items": [
  {"n": 88, "kind": "flavor", "loc": "cards-race.txt [c-human-tailwind] 순풍 (공격+드로우)", "text": "\"등을 밀어 주는 바람은 사양하지 않아.\""},
  {"n": 89, "kind": "flavor", "loc": "cards-race.txt [c-human-adapt] 적응 (방어+드로우)", "text": "\"금방 익숙해져, 어디든.\""},
  {"n": 90, "kind": "flavor", "loc": "cards-race.txt [c-human-evenblade] 평정의 검 (가장 낮은 색만큼)", "text": "\"잘하는 것만 늘리면 못하는 게 발목을 잡지.\""},
  {"n": 91, "kind": "flavor", "loc": "cards-race.txt [c-human-adaptstrike] 임기응변 (상황 따라 공/방)", "text": "\"정답은 그때그때 달라.\""},
  {"n": 92, "kind": "flavor", "loc": "cards-race.txt [c-human-hamstring] 다리 후리기 (약화)", "text": "\"위만 보다가 아래를 놓치면 안 되지.\""},
  {"n": 93, "kind": "flavor", "loc": "cards-race.txt [c-human-shatterguard] 무릎 꺾기 (방어 약화)", "text": "\"방패는 손이 아니라 무릎이 들고 있는 거야.\""},
  {"n": 94, "kind": "flavor", "loc": "cards-race.txt [c-human-combo] 연계기 (빈틈+약화+공격)", "text": "\"순서만 지키면 돼.\""},
  {"n": 95, "kind": "flavor", "loc": "cards-race.txt [c-human-regroup] 재정비 (방어+드로우)", "text": "\"물러서는 것도 걸음이야.\""},
  {"n": 96, "kind": "flavor", "loc": "cards-race.txt [c-human-allout] 전심전력 (공+방+드로우)", "text": "\"오늘 몫은 오늘 다 써야지.\""},
  {"n": 97, "kind": "flavor", "loc": "cards-race.txt [c-human-focuspoint] 일점집중 (다음 카드 강화)", "text": "\"하나만 본다. 하나만.\""},
  {"n": 98, "kind": "flavor", "loc": "cards-race.txt [c-human-tradeblow] 맞받아치기 (공+방 균등)", "text": "주고받는 셈은 정확해야지."},
  {"n": 99, "kind": "flavor", "loc": "cards-race.txt [c-human-counterstance] 반격 자세", "text": "\"막는 자세랑 치는 자세는 원래 같은 거야.\""},
  {"n": 100, "kind": "flavor", "loc": "cards-race.txt [c-human-pivot] 받아흘리기", "text": "\"힘은 부딪치는 게 아니라 빌리는 거야.\""},
  {"n": 101, "kind": "flavor", "loc": "cards-race.txt [c-human-fairtrade] 등가교환", "text": "\"셈은 칼끝에서도 정확하게.\""},
  {"n": 102, "kind": "name·개명 제안", "loc": "cards-race.txt [c-human-tempo] · '박자' 금칙어 카드명", "text": "박자 맞추기", "proposal": "완급 조절"},
  {"n": 103, "kind": "flavor", "loc": "cards-race.txt [c-human-tempo] (개명안 '완급 조절' 기준)", "text": "\"빠르게만 친다고 이기는 게 아니야.\""},
  {"n": 104, "kind": "flavor", "loc": "cards-race.txt [c-human-foresight] 선견 (빛 기운 조건 드로우)", "text": "맑은 날에는 멀리까지 보인다."},
  {"n": 105, "kind": "flavor", "loc": "cards-race.txt [c-human-stockpile] 비축 (다음 턴 마나)", "text": "\"아껴 둔 게 있다는 건 든든한 일이지.\""},
  {"n": 106, "kind": "flavor", "loc": "cards-race.txt [c-human-disarm] 무장 해제 (약화)", "text": "\"그 손에서 힘 빼. 다친다.\""},
  {"n": 107, "kind": "flavor", "loc": "cards-race.txt [c-human-expose] 허점 노출 (방어+취약)", "text": "\"잘 막는 사람이 빈틈도 잘 봐.\""},
  {"n": 108, "kind": "flavor", "loc": "cards-race.txt [c-human-emberbrand] 불씨 낙인 (화상)", "text": "불씨는 작을 때 옮겨붙는다."},
  {"n": 109, "kind": "flavor", "loc": "cards-race.txt [c-human-fullbreak] 전열 붕괴", "text": "\"무너질 때는 한꺼번에 무너져.\""},
  {"n": 110, "kind": "flavor", "loc": "cards-race.txt [c-human-followthrough] 마무리 추격 (취약 소비)", "text": "\"벌어진 틈은 닫히기 전에 써야지.\""},
  {"n": 111, "kind": "flavor", "loc": "cards-race.txt [c-human-leveler] 고른 손 (가장 낮은 색만큼)", "text": "\"어느 손도 놀려 두지 않아.\""},
  {"n": 112, "kind": "flavor", "loc": "cards-race.txt [c-human-bulwarkblow] 방패 치기", "text": "\"방패는 치라고 있는 거기도 해.\""},
  {"n": 113, "kind": "flavor", "loc": "cards-race.txt [c-human-steadfast] 굳건함 (방어+공격)", "text": "\"발이 땅을 믿어야 검이 안 흔들려.\""},
  {"n": 114, "kind": "flavor", "loc": "cards-race.txt [c-human-shiftguard] 변수 대응", "text": "\"놀라지 않는 연습부터 했어.\""},
  {"n": 115, "kind": "flavor", "loc": "cards-race.txt [c-human-decisive] 결정타", "text": "\"망설이면 두 번 쳐야 해.\""},
  {"n": 116, "kind": "flavor", "loc": "cards-race.txt [c-human-lastline] 최후의 방어선", "text": "\"여기서부터는 못 지나가.\""},
  {"n": 117, "kind": "flavor", "loc": "cards-race.txt [c-human-overcome] 극복", "text": "\"넘고 나면 별것 아니었다고 하겠지.\""},
  {"n": 118, "kind": "flavor", "loc": "cards-race.txt [c-human-jab] 잽 (저비용)", "text": "\"가볍게, 가볍게.\""},
  {"n": 119, "kind": "flavor", "loc": "cards-race.txt [c-human-brace] 발 디디기 (저비용 방어)", "text": "우선 발부터."},
  {"n": 120, "kind": "flavor", "loc": "cards-race.txt [c-human-bloodrage] 피의 격노 (체력 소모)", "text": "\"피가 나야 정신이 들 때도 있어.\""},
  {"n": 121, "kind": "flavor", "loc": "cards-race.txt [c-moth-gale] 돌풍 (2연사)", "text": "\"바람 방향 좋을 때 몰아치자!\""},
  {"n": 122, "kind": "flavor", "loc": "cards-race.txt [c-moth-quickjab] 속타 (저비용)", "text": "\"맞았지? 방금 맞았어.\""},
  {"n": 123, "kind": "flavor", "loc": "cards-race.txt [c-moth-barrage] 난사 (3연사)", "text": "\"조준? 다 맞으면 조준이지!\""},
  {"n": 124, "kind": "flavor", "loc": "cards-race.txt [c-moth-combostrike] 연격 (낸 카드 수만큼)", "text": "\"흐름 끊지 마, 지금 좋으니까!\""},
  {"n": 125, "kind": "flavor", "loc": "cards-race.txt [c-moth-gust] 질풍 (손패 비용 감소)", "text": "순풍에는 모든 짐이 가볍다."},
  {"n": 126, "kind": "flavor", "loc": "cards-race.txt [c-moth-flurry] 날개 폭풍 (4연타+드로우)", "text": "날갯짓 넷이면 작은 폭풍이 된다."},
  {"n": 127, "kind": "flavor", "loc": "cards-race.txt [c-moth-accel] 순풍 가속 (드로우+다음 턴 마나)", "text": "\"가속 구간이야!\""},
  {"n": 128, "kind": "flavor", "loc": "cards-race.txt [c-moth-scatter] 흩날리기 (빛가루)", "text": "날개에서 떨어진 빛가루는 그냥 떨어지는 법이 없다."},
  {"n": 129, "kind": "flavor", "loc": "cards-race.txt [c-moth-dive] 급강하 (공격+드로우)", "text": "\"높이 나는 건 내려찍으려고!\""},
  {"n": 130, "kind": "flavor", "loc": "cards-race.txt [c-moth-blitz] 연참 (3연타+드로우)", "text": "\"눈 깜빡이면 끝나 있을걸.\""},
  {"n": 131, "kind": "flavor", "loc": "cards-race.txt [c-moth-glidewall] 활강 방벽 (방어+드로우)", "text": "기울인 날개가 바람을 받아넘긴다."},
  {"n": 132, "kind": "flavor", "loc": "cards-race.txt [c-moth-pinprick] 콕 찌르기 (저비용 단타)", "text": "\"콕.\""},
  {"n": 133, "kind": "flavor", "loc": "cards-race.txt [c-moth-flick] 튕기기 (저비용 단타)", "text": "튕기는 맛이 은근히 좋다."},
  {"n": 134, "kind": "flavor", "loc": "cards-race.txt [c-moth-glance] 빗겨막기 (저비용 방어)", "text": "정면으로 받아 줄 이유가 없다."},
  {"n": 135, "kind": "flavor", "loc": "cards-race.txt [c-moth-spark] 잔불 (화상)", "text": "깃을 스친 것만으로도 데인다."},
  {"n": 136, "kind": "flavor", "loc": "cards-race.txt [c-moth-triplet] 세 발 (3연사)", "text": "\"세 발이면 보통 끝나.\""},
  {"n": 137, "kind": "flavor", "loc": "cards-race.txt [c-moth-rapidfire] 속사 연발 (4연사)", "text": "시위 소리가 하나로 이어져 들린다."},
  {"n": 138, "kind": "flavor", "loc": "cards-race.txt [c-moth-volleyup] 모아 쏘기 (2발 강타)", "text": "\"숨 참고...... 지금!\""},
  {"n": 139, "kind": "flavor", "loc": "cards-race.txt [c-moth-stinger] 연침 (2연타+약화)", "text": "침 끝에 힘 빼는 약을 발라 뒀다."},
  {"n": 140, "kind": "flavor", "loc": "cards-race.txt [c-moth-windlash] 바람 채찍 (3연타)", "text": "바람도 휘어잡으면 채찍이 된다."},
  {"n": 141, "kind": "flavor", "loc": "cards-race.txt [c-moth-tempocut] 흐름 베기 (낸 카드 수만큼)", "text": "\"지금 분위기 좋다, 그치?\""},
  {"n": 142, "kind": "flavor", "loc": "cards-race.txt [c-moth-crescendo] 고조 (낸 카드 수만큼)", "text": "노래도 싸움도 끝에서 제일 커진다."},
  {"n": 143, "kind": "flavor", "loc": "cards-race.txt [c-moth-overdrive] 과속 (이번 턴 강화)", "text": "\"멈추는 법은 안 배웠어!\""},
  {"n": 144, "kind": "flavor", "loc": "cards-race.txt [c-moth-cadence] 가락 (낸 카드 수만큼+드로우)", "text": "콧노래에 맞춰 손이 움직인다."},
  {"n": 145, "kind": "flavor", "loc": "cards-race.txt [c-moth-updraft] 상승 기류 (드로우 2)", "text": "바람이 밑에서 받쳐 주면 날개는 쉰다."},
  {"n": 146, "kind": "flavor", "loc": "cards-race.txt [c-moth-circling] 선회 (드로우, 소멸)", "text": "크게 돌아보면 못 보던 게 보인다."},
  {"n": 147, "kind": "flavor", "loc": "cards-race.txt [c-moth-loop] 되돌이 바람 (손으로 복귀)", "text": "이 바람은 갔다가 꼭 돌아온다."},
  {"n": 148, "kind": "flavor", "loc": "cards-race.txt [c-moth-haste] 가벼운 몸 (비용 감소+드로우)", "text": "\"오늘따라 몸이 가벼워!\""},
  {"n": 149, "kind": "flavor", "loc": "cards-race.txt [c-moth-slipstream] 바람 길 (비용 감소)", "text": "앞선 바람이 터 놓은 길은 날기 쉽다."},
  {"n": 150, "kind": "flavor", "loc": "cards-race.txt [c-moth-tempest] 폭풍우 (3연타)", "text": "비바람 치는 날에도 사냥은 한다."},
  {"n": 151, "kind": "flavor", "loc": "cards-race.txt [c-moth-cyclone] 회오리 (4연타+드로우)", "text": "휘말리면 빠져나올 때까지 맞는 수밖에 없다."},
  {"n": 152, "kind": "flavor", "loc": "cards-race.txt [c-moth-skyfall] 빛살 낙하 (낸 카드 수만큼)", "text": "구름 사이로 빛이 기둥처럼 꽂히는 날이 있다."},
  {"n": 153, "kind": "flavor", "loc": "cards-race.txt [c-moth-poise] 자세잡기 (민첩+드로우)", "text": "\"어깨 펴고, 시위는 부드럽게.\""},
  {"n": 154, "kind": "flavor", "loc": "cards-race.txt [c-moth-toxinburst] 화상 점화 (화상 소비)", "text": "\"불씨 회수! 크게 터뜨리자!\""},
  {"n": 155, "kind": "flavor", "loc": "cards-race.txt [c-moth-shiv] 잰단검 (1회용)", "text": "쓰고 버리는 칼이라 망설임이 없다."},
  {"n": 156, "kind": "flavor·PENDING", "loc": "cards-race.txt [c-moth-needle] (개명 확정 '바늘땀', 3차 X 재수정)", "text": "\"움직이면 삐뚤어져.\""}
 ]
}
