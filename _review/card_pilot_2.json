  {"n": 25, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-fold] 접기", "text": "\"이번 판은 접을게.\" 그 말을 믿은 사람이 졌다."},
  {"n": 26, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-redeal] 다시 돌리기", "text": "\"마음에 안 들면 다시 돌리면 돼.\""},
