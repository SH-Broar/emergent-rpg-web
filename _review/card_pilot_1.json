  "title": "카드 flavor 파일럿 40 (가이드 v1.4)"
 },
 "items": [
  {"n": 1, "kind": "flavor·확정 재확인", "loc": "cards-race.txt [c-human-balance] 균형의 일격", "text": "\"균형을 지키는 것이야말로 발전의 지름길이니\""},
  {"n": 2, "kind": "flavor·확정 재확인", "loc": "cards-race.txt [c-human-balance-plus] 균형의 일격+", "text": "\"마음에 흔들림이 있다면 더욱 수련에 정진해야 한다\""},
  {"n": 3, "kind": "flavor·교정 채택", "loc": "cards-race.txt [c-human-warcry] 전의의 외침", "text": "\"전장에선 큰 함성이 칼보다 효과적이다.\""},
  {"n": 4, "kind": "flavor·교정 채택", "loc": "cards-race.txt [c-human-resolve] 각오", "text": "마치 물러설 곳이 없는 듯이."},
  {"n": 5, "kind": "flavor·교정 채택", "loc": "cards-race.txt [c-moth-stormcall] 폭풍 부르기", "text": "\"바람이 우리를 도와 줄 거야.\""},
  {"n": 6, "kind": "flavor·확정 재확인", "loc": "cards-race.txt [c-phantom-handguard] 패의 방벽", "text": "보여 줄 수 있는 패가 많다는 건, 숨긴 패도 많다는 뜻."},
  {"n": 7, "kind": "flavor·확정 재확인", "loc": "cards-mvr.txt [c-strike] 일격", "text": "어디서든 통하는 가장 오래된 수."},
  {"n": 8, "kind": "flavor·확정 재확인", "loc": "cards-mvr.txt [c-recover] 숨 고르기", "text": "싸움의 절반은 숨이다."},
  {"n": 9, "kind": "flavor·신규", "loc": "cards-mvr.txt [c-defend] 방어", "text": "막는 법부터 배운다."},
  {"n": 10, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-empty] 무의 검", "text": "마술사의 손은 패를 전부 내려놓은 뒤가 진짜다."},
  {"n": 11, "kind": "flavor·신규", "loc": "cards-race.txt [c-moth-doubletap] 두 발", "text": "\"첫 발이 빗나가도 괜찮아. 그래서 두 발이야.\""},
  {"n": 12, "kind": "flavor·신규", "loc": "cards-race.txt [c-arcana-spark] 작은 빛", "text": "손끝의 빛이 어둠을 조금 밀어낸다."},
  {"n": 13, "kind": "flavor·신규", "loc": "cards-race.txt [c-arcana-judgment] 공명 심판", "text": "하늘이 잠깐 여덟 가지 색으로 갈라진다."},
  {"n": 14, "kind": "flavor·신규", "loc": "transform-forms.txt [c-fox-pounce] 덮치기", "text": "네 발이 이렇게 빠를 줄은 몰랐다."},
  {"n": 15, "kind": "flavor·신규", "loc": "cards-race.txt [c-human-pin] 급소 찌르기", "text": "\"급소는 외우는 게 아니야. 손이 기억하는 거지.\""},
  {"n": 16, "kind": "flavor·신규", "loc": "cards-race.txt [c-human-bulwark] 철벽", "text": "성문이 닫히는 소리는 어디서나 같다."},
  {"n": 17, "kind": "flavor·신규", "loc": "cards-race.txt [c-human-improvise] 즉흥", "text": "\"계획? 그런 건 칼 뽑기 전 얘기지.\""},
  {"n": 18, "kind": "flavor·신규", "loc": "cards-race.txt [c-human-secondwind] 호흡 고르기", "text": "\"지친 게 아니야. 고르는 중이야.\""},
  {"n": 19, "kind": "flavor·신규", "loc": "cards-race.txt [c-human-finalblow] 최후 일격", "text": "\"마지막은 망설이면 안 돼. 상대에 대한 예의야.\""},
  {"n": 20, "kind": "flavor·신규", "loc": "cards-race.txt [c-moth-volley] 속사", "text": "나무 위에서 쏘면 바람이 화살을 데려간다."},
  {"n": 21, "kind": "flavor·신규", "loc": "cards-race.txt [c-moth-glide] 활강", "text": "숲의 가장 높은 가지에서 보면 길이 먼저 보인다."},
  {"n": 22, "kind": "flavor·신규", "loc": "cards-race.txt [c-moth-clearsky] 맑은 하늘", "text": "\"오늘은 날씨가 좋네! 멀리까지 가자!\""},
  {"n": 23, "kind": "flavor·신규", "loc": "cards-race.txt [c-moth-needle] 쌍침", "text": "두 개의 바늘이 거의 같은 자리에 박힌다."},
  {"n": 24, "kind": "flavor·신규", "loc": "cards-race.txt [c-moth-windgather] 바람갈무리", "text": "사냥 전엔 깃을 다듬으며 바람을 기다린다."},
  {"n": 25, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-blackout] 정전", "text": "불이 꺼진 사이에 무언가 지나갔다고들 한다."},
  {"n": 26, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-shroud] 장막", "text": "장막을 걷었을 때는 이미 아무것도 없었다."},
  {"n": 27, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-static] 감전", "text": "\"손끝이 짜릿한 건 기분 탓이야.\""},
  {"n": 28, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-trickhand] 손속임", "text": "왼손을 보여 주는 동안 오른손이 일한다."},
  {"n": 29, "kind": "flavor·신규", "loc": "cards-race.txt [c-phantom-lastcard] 마지막 한 장", "text": "\"마지막 장은 아껴 두는 거야.\""},
  {"n": 30, "kind": "flavor·신규", "loc": "cards-race.txt [c-arcana-rainbow] 무지개", "text": "비가 그친 하늘에 여덟 색이 잠깐 걸린다."},
  {"n": 31, "kind": "flavor·신규", "loc": "cards-race.txt [c-arcana-glare] 눈부심", "text": "\"똑바로 보면 안 돼!\""},
  {"n": 32, "kind": "flavor·신규", "loc": "cards-race.txt [c-arcana-wellspring] 마나 샘", "text": "마르지 않는 샘이 있다는 이야기는 어느 마을에나 있다."},
  {"n": 33, "kind": "flavor·신규", "loc": "cards-race.txt [c-arcana-mantle] 빛의 외투", "text": "어깨에 빛을 두르면 조금 따뜻하다."},
  {"n": 34, "kind": "flavor·신규", "loc": "cards-mvr.txt [c-shop-heavy] 묵직한 일격", "text": "\"비싼 값을 하는 물건입니다.\""},
  {"n": 35, "kind": "flavor·신규", "loc": "cards-mvr.txt [c-iluneon-stopped-noon] 멈춘 시계", "text": "일루네온의 큰 시계는 가끔 정오에 멈춘다."},
  {"n": 36, "kind": "flavor·신규", "loc": "cards-mvr.txt [c-manonickla-sunset-wall] 석양의 벽", "text": "마노니클라의 노을은 좀처럼 지지 않는다."},
  {"n": 37, "kind": "flavor·신규", "loc": "cards-mvr.txt [c-tacomi-hologram-mirror] 홀로매트릭스", "text": "나이트 타코미의 밤엔 진짜보다 선명한 가짜가 떠다닌다."},
  {"n": 38, "kind": "flavor·신규", "loc": "transform-forms.txt [c-fox-lick] 상처 핥기", "text": "혀로 핥는 게 제일 빠르다니, 아직도 어색하다."},
  {"n": 39, "kind": "flavor·신규", "loc": "transform-forms.txt [c-fox-nine-tails] 아홉 꼬리", "text": "\"어때, 아홉 개나 있으면 편리하지?\""},
  {"n": 40, "kind": "flavor·신규", "loc": "transform-forms.txt [c-fox-prowl] 살금걸음", "text": "발소리가 나지 않는 몸이라는 게, 조금 즐거워졌다."}
 ]
}
